{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EyeBreak",
  "version": "0.1.0",
  "identifier": "us.frankmaruf.eyebreak",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "EyeBreak",
        "width": 760,
        "height": 680,
        "minWidth": 520,
        "minHeight": 520,
        "resizable": true,
        "visible": true
      },
      {
        "label": "widget",
        "url": "index.html#widget",
        "title": "EyeBreak widget",
        "width": 150,
        "height": 150,
        "minWidth": 80,
        "minHeight": 80,
        "maxWidth": 480,
        "maxHeight": 480,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
