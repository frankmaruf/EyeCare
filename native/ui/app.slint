import { Theme, Ring, PillButton, Card, NumberField, ToggleRow, IconButton, DayChip } from "theme.slint";
import { ScrollView, ComboBox } from "std-widgets.slint";

// re-export so the Theme global is reachable from Rust (appearance settings)
export { Theme }

// Dashboard — mirrors showDashboard() in eyecare/src/main.ts.
export component MainWindow inherits Window {
    title: "EyeCare";
    icon: @image-url("icon.png");
    width: 360px;
    height: 440px;
    background: Theme.bg;

    in property <float> progress: 1.0;
    in property <string> time-text: "20:00";
    in property <string> label-text: "until next break";
    in property <string> phase-tag: "working";
    in property <string> pause-text: "Pause";
    callback pause();
    callback take-break();
    callback skip();
    callback open-settings();

    VerticalLayout {
        padding: 24px;
        spacing: 18px;

        // header: title + phase tag + settings
        HorizontalLayout {
            spacing: 10px;
            Text {
                text: "EyeCare";
                color: Theme.text;
                font-size: 24px;
                font-weight: 700;
                vertical-alignment: center;
            }

            Rectangle {
                background: #1d2c47;
                border-radius: 999px;
                border-width: 1px;
                border-color: Theme.border;
                horizontal-stretch: 0;
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    padding-top: 4px;
                    padding-bottom: 4px;
                    Text {
                        text: root.phase-tag;
                        color: Theme.accent;
                        font-size: 12px;
                        font-weight: 600;
                    }
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            gear := Rectangle {
                width: 34px;
                height: 34px;
                border-radius: 8px;
                border-width: 1px;
                border-color: Theme.border;
                background: gear-touch.has-hover ? #ffffff10 : transparent;
                Text {
                    text: "⚙";
                    color: Theme.muted;
                    font-size: 18px;
                }

                gear-touch := TouchArea {
                    clicked => {
                        root.open-settings();
                    }
                }
            }
        }

        // ring fills the free space, centred
        Rectangle {
            vertical-stretch: 1;
            Ring {
                progress: root.progress;
                time-text: root.time-text;
                label-text: root.label-text;
            }
        }

        // controls
        HorizontalLayout {
            alignment: center;
            spacing: 10px;
            PillButton {
                text: root.pause-text;
                clicked => {
                    root.pause();
                }
            }

            PillButton {
                text: "Take break now";
                ghost: true;
                clicked => {
                    root.take-break();
                }
            }

            PillButton {
                text: "Skip";
                ghost: true;
                clicked => {
                    root.skip();
                }
            }
        }
    }
}

// Break overlay — mirrors renderBreak() in eyecare/src/main.ts.
export component BreakWindow inherits Window {
    title: "EyeCare — break time";
    icon: @image-url("icon.png");
    width: 580px;
    height: 480px;
    background: Theme.bg;

    in property <string> time-text: "00:20";
    in property <string> title-text: "Look ~20 feet away";
    in property <string> sub-text: "Relax your eyes — let your focus drift to the distance.";
    in property <string> tip-text;
    in property <bool> can-postpone: true;
    in property <bool> calm-on: true;
    in property <bool> exercise-on: false;
    in property <bool> is-long: false;
    callback postpone();
    callback skip();

    // calming drifting colour blobs behind the content
    if root.calm-on: Rectangle {
        width: 100%;
        height: 100%;
        Rectangle {
            width: 340px;
            height: 340px;
            border-radius: 170px;
            background: #2bd0c826;
            x: -70px;
            y: -90px;
        }

        Rectangle {
            width: 300px;
            height: 300px;
            border-radius: 150px;
            background: #4a7bd026;
            x: parent.width - 230px;
            y: parent.height - 210px;
        }
    }

    VerticalLayout {
        padding: 24px;
        spacing: 8px;
        alignment: center;

        Text {
            text: "EYECARE";
            color: Theme.accent;
            font-size: 13px;
            letter-spacing: 3px;
            font-weight: 600;
            horizontal-alignment: center;
        }

        Text {
            text: root.title-text;
            color: Theme.text;
            font-size: 36px;
            font-weight: 600;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        Text {
            text: root.sub-text;
            color: Theme.muted;
            font-size: 16px;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        // guided eye-exercise: follow the dot (long breaks only)
        if root.exercise-on && root.is-long: Rectangle {
            height: 64px;
            Rectangle {
                width: 16px;
                height: 16px;
                border-radius: 8px;
                background: Theme.accent;
                y: parent.height / 2 - 8px;
                x: parent.width / 2 - 8px + 120px * Math.sin((animation-tick() / 1s) * 90deg);
            }
        }

        Text {
            text: root.time-text;
            color: Theme.accent;
            font-size: 64px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        HorizontalLayout {
            alignment: center;
            spacing: 12px;
            PillButton {
                text: "Postpone";
                ghost: true;
                clicked => {
                    root.postpone();
                }
            }

            PillButton {
                text: "Skip break";
                clicked => {
                    root.skip();
                }
            }
        }

        Text {
            text: root.tip-text;
            color: Theme.muted;
            font-size: 14px;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
    }
}

// Settings — mirrors showSettings() in eyecare/src/main.ts (core cards now;
// nudges / theme / stats / import-export land in later increments).
export component SettingsWindow inherits Window {
    title: "EyeCare — Settings";
    icon: @image-url("icon.png");
    width: 440px;
    height: 600px;
    background: Theme.bg;

    in-out property <int> work-min;
    in-out property <int> break-sec;
    in-out property <int> prewarn-sec;
    in-out property <int> escalation-idx;
    in-out property <bool> sound-enabled;
    in-out property <int> snooze-min;
    in-out property <int> max-postpones;
    in-out property <int> accent-idx;
    in-out property <bool> reduce-motion;
    in-out property <bool> high-contrast;
    in-out property <bool> autostart;
    in-out property <bool> idle-enabled;
    in-out property <int> idle-sec;
    in-out property <bool> wh-enabled;
    in-out property <int> wh-start-h;
    in-out property <int> wh-start-m;
    in-out property <int> wh-end-h;
    in-out property <int> wh-end-m;
    in-out property <bool> wd-mon;
    in-out property <bool> wd-tue;
    in-out property <bool> wd-wed;
    in-out property <bool> wd-thu;
    in-out property <bool> wd-fri;
    in-out property <bool> wd-sat;
    in-out property <bool> wd-sun;
    in-out property <bool> evening-enabled;
    in-out property <int> evening-hour;
    in-out property <bool> long-enabled;
    in-out property <int> long-every;
    in-out property <int> long-min;
    in-out property <bool> tips-enabled;
    in-out property <bool> exercises-enabled;
    in-out property <bool> calm-enabled;
    in-out property <bool> blink-enabled;
    in-out property <int> blink-min;
    in-out property <bool> hydration-enabled;
    in-out property <int> hydration-min;
    in-out property <bool> posture-enabled;
    in-out property <int> posture-min;
    in-out property <bool> eyedrops-enabled;
    in-out property <int> eyedrops-min;
    in-out property <int> widget-shape-idx;
    in-out property <int> widget-opacity;
    in-out property <int> widget-w;
    in-out property <int> widget-h;
    in property <string> long-hint;
    callback save();
    callback back();

    VerticalLayout {
        padding: 20px;
        spacing: 14px;

        HorizontalLayout {
            spacing: 10px;
            Text {
                text: "Settings";
                color: Theme.text;
                font-size: 20px;
                font-weight: 700;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
        }

        ScrollView {
            vertical-stretch: 1;
            VerticalLayout {
                spacing: 14px;

                Card {
                    title: "Timing";
                    NumberField {
                        label: "Work interval";
                        unit: "min";
                        value <=> root.work-min;
                        minimum: 1;
                        maximum: 120;
                    }

                    NumberField {
                        label: "Break length";
                        unit: "sec";
                        value <=> root.break-sec;
                        minimum: 5;
                        maximum: 600;
                    }

                    NumberField {
                        label: "Pre-break warning";
                        unit: "sec, 0=off";
                        value <=> root.prewarn-sec;
                        minimum: 0;
                        maximum: 120;
                    }
                }

                Card {
                    title: "Long breaks";
                    ToggleRow {
                        label: "Enable long breaks";
                        checked <=> root.long-enabled;
                    }

                    NumberField {
                        label: "Every Nth break";
                        unit: "breaks";
                        value <=> root.long-every;
                        minimum: 1;
                        maximum: 10;
                    }

                    NumberField {
                        label: "Long break length";
                        unit: "min";
                        value <=> root.long-min;
                        minimum: 1;
                        maximum: 60;
                    }

                    Text {
                        text: root.long-hint;
                        color: Theme.muted;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }

                Card {
                    title: "Reminders";
                    HorizontalLayout {
                        height: 32px;
                        spacing: 8px;
                        Text {
                            text: "Intensity";
                            color: Theme.text;
                            font-size: 14px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        ComboBox {
                            model: ["gentle", "standard", "forced"];
                            current-index <=> root.escalation-idx;
                            width: 130px;
                        }
                    }

                    ToggleRow {
                        label: "Play a sound on break";
                        checked <=> root.sound-enabled;
                    }

                    NumberField {
                        label: "Snooze / postpone";
                        unit: "min";
                        value <=> root.snooze-min;
                        minimum: 1;
                        maximum: 60;
                    }

                    NumberField {
                        label: "Max postpones";
                        unit: "0=∞";
                        value <=> root.max-postpones;
                        minimum: 0;
                        maximum: 10;
                    }

                    ToggleRow {
                        label: "Show eye-care tips on the break screen";
                        checked <=> root.tips-enabled;
                    }

                    ToggleRow {
                        label: "Guided eye-exercise on long breaks";
                        checked <=> root.exercises-enabled;
                    }

                    ToggleRow {
                        label: "Calming visuals on the break screen";
                        checked <=> root.calm-enabled;
                    }
                }

                Card {
                    title: "Wellbeing nudges";
                    ToggleRow {
                        label: "Blink reminder";
                        checked <=> root.blink-enabled;
                    }

                    NumberField {
                        label: "Blink every";
                        unit: "min";
                        value <=> root.blink-min;
                        minimum: 1;
                        maximum: 120;
                    }

                    ToggleRow {
                        label: "Hydration reminder";
                        checked <=> root.hydration-enabled;
                    }

                    NumberField {
                        label: "Hydrate every";
                        unit: "min";
                        value <=> root.hydration-min;
                        minimum: 5;
                        maximum: 240;
                    }

                    ToggleRow {
                        label: "Posture reminder";
                        checked <=> root.posture-enabled;
                    }

                    NumberField {
                        label: "Posture every";
                        unit: "min";
                        value <=> root.posture-min;
                        minimum: 5;
                        maximum: 240;
                    }

                    ToggleRow {
                        label: "Eye-drops / artificial tears";
                        checked <=> root.eyedrops-enabled;
                    }

                    NumberField {
                        label: "Eye-drops every";
                        unit: "min";
                        value <=> root.eyedrops-min;
                        minimum: 5;
                        maximum: 480;
                    }

                    ToggleRow {
                        label: "Evening warm-screen nudge";
                        checked <=> root.evening-enabled;
                    }

                    NumberField {
                        label: "Evening hour";
                        unit: "0–23";
                        value <=> root.evening-hour;
                        minimum: 0;
                        maximum: 23;
                    }
                }

                Card {
                    title: "Work hours";
                    ToggleRow {
                        label: "Only remind during work hours";
                        checked <=> root.wh-enabled;
                    }

                    NumberField {
                        label: "Start hour";
                        unit: "0–23";
                        value <=> root.wh-start-h;
                        minimum: 0;
                        maximum: 23;
                    }

                    NumberField {
                        label: "Start minute";
                        unit: "";
                        value <=> root.wh-start-m;
                        minimum: 0;
                        maximum: 59;
                    }

                    NumberField {
                        label: "End hour";
                        unit: "0–23";
                        value <=> root.wh-end-h;
                        minimum: 0;
                        maximum: 23;
                    }

                    NumberField {
                        label: "End minute";
                        unit: "";
                        value <=> root.wh-end-m;
                        minimum: 0;
                        maximum: 59;
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        alignment: start;
                        DayChip { label: "M"; on <=> root.wd-mon; }
                        DayChip { label: "T"; on <=> root.wd-tue; }
                        DayChip { label: "W"; on <=> root.wd-wed; }
                        DayChip { label: "T"; on <=> root.wd-thu; }
                        DayChip { label: "F"; on <=> root.wd-fri; }
                        DayChip { label: "S"; on <=> root.wd-sat; }
                        DayChip { label: "S"; on <=> root.wd-sun; }
                    }
                }

                Card {
                    title: "Floating widget";
                    HorizontalLayout {
                        height: 32px;
                        spacing: 8px;
                        Text {
                            text: "Shape";
                            color: Theme.text;
                            font-size: 14px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        ComboBox {
                            model: ["round", "squircle", "square"];
                            current-index <=> root.widget-shape-idx;
                            width: 130px;
                        }
                    }

                    NumberField {
                        label: "Opacity";
                        unit: "%";
                        value <=> root.widget-opacity;
                        minimum: 20;
                        maximum: 100;
                    }

                    NumberField {
                        label: "Width";
                        unit: "px";
                        value <=> root.widget-w;
                        minimum: 120;
                        maximum: 480;
                    }

                    NumberField {
                        label: "Height";
                        unit: "px";
                        value <=> root.widget-h;
                        minimum: 120;
                        maximum: 480;
                    }
                }

                Card {
                    title: "System";
                    ToggleRow {
                        label: "Launch at login";
                        checked <=> root.autostart;
                    }
                }

                Card {
                    title: "Stay out of the way";
                    ToggleRow {
                        label: "Pause when I'm away (idle)";
                        checked <=> root.idle-enabled;
                    }

                    NumberField {
                        label: "Idle threshold";
                        unit: "sec";
                        value <=> root.idle-sec;
                        minimum: 10;
                        maximum: 1800;
                    }
                }

                Card {
                    title: "Appearance";
                    HorizontalLayout {
                        height: 30px;
                        spacing: 8px;
                        Text {
                            text: "Accent";
                            color: Theme.text;
                            font-size: 14px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        for col[i] in [#4cc6c0, #34d399, #5b8def, #e2725b, #a78bfa, #f59e0b]: Rectangle {
                            width: 24px;
                            height: 24px;
                            border-radius: 12px;
                            background: col;
                            border-width: root.accent-idx == i ? 3px : 0px;
                            border-color: #ffffff;
                            TouchArea {
                                clicked => {
                                    root.accent-idx = i;
                                }
                            }
                        }
                    }

                    ToggleRow {
                        label: "Reduce motion (no animations)";
                        checked <=> root.reduce-motion;
                    }

                    ToggleRow {
                        label: "High contrast";
                        checked <=> root.high-contrast;
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 10px;
            alignment: start;
            PillButton {
                text: "Save settings";
                clicked => {
                    root.save();
                }
            }

            PillButton {
                text: "Back";
                ghost: true;
                clicked => {
                    root.back();
                }
            }
        }
    }
}

// Floating widget — mirrors renderWidget(): small always-on-top countdown ring.
export component WidgetWindow inherits Window {
    title: "EyeCare widget";
    icon: @image-url("icon.png");
    width: 132px;
    height: 132px;
    background: transparent;
    no-frame: true;

    in property <float> progress: 1.0;
    in property <string> time-text: "20:00";
    in property <string> pause-icon: "⏸";
    in property <string> shape: "squircle";
    in property <float> opacity-frac: 0.95;
    callback restore();
    callback pause();
    callback take-break();
    callback skip();
    callback start-drag();
    callback start-resize();

    card := Rectangle {
        width: 100%;
        height: 100%;
        border-radius: root.shape == "round"
            ? self.width / 2
            : (root.shape == "square" ? 10px : 28px);
        background: rgba(14, 23, 38, root.opacity-frac);
        border-width: 1px;
        border-color: #2b3a57;

        // press-and-drag the body to move the widget (matches startDragging)
        hover := TouchArea {
            mouse-cursor: grab;
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                    root.start-drag();
                }
            }
        }

        // ---- ring with tick marks ----
        ringbox := Rectangle {
            width: 104px;
            height: 104px;
            y: 8px;
            x: (parent.width - self.width) / 2;

            // track
            Rectangle {
                width: 100%;
                height: 100%;
                border-radius: self.width / 2;
                border-width: 9px;
                border-color: Theme.ring-track;
            }

            // 12 tick dots around the dial (placed by angle; no rotation API)
            for i in 12: Rectangle {
                width: 3px;
                height: 3px;
                border-radius: 1.5px;
                background: #3a4a66;
                x: 52px + 34px * Math.sin(i * 30deg) - 1.5px;
                y: 52px - 34px * Math.cos(i * 30deg) - 1.5px;
            }

            // progress arc
            Path {
                width: 100%;
                height: 100%;
                viewbox-width: 100;
                viewbox-height: 100;
                stroke: Theme.accent;
                stroke-width: 9px;
                MoveTo {
                    x: 50;
                    y: 6;
                }
                ArcTo {
                    radius-x: 44;
                    radius-y: 44;
                    x: 50 + 44 * Math.sin(root.progress * 360deg);
                    y: 50 - 44 * Math.cos(root.progress * 360deg);
                    large-arc: root.progress > 0.5;
                    sweep: true;
                }
            }

            Text {
                text: root.time-text;
                color: Theme.text;
                font-size: 27px;
                font-weight: 700;
                width: 100%;
                height: 100%;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // ---- expand-to-restore (top-right, on hover) ----
        restore-btn := Rectangle {
            x: parent.width - 28px;
            y: 7px;
            width: 21px;
            height: 21px;
            border-radius: 7px;
            background: rt.has-hover ? #2a3a59 : #1c2a45;
            opacity: hover.has-hover ? 1.0 : 0.0;
            animate opacity { duration: Theme.anim; }
            Text {
                text: "⤢";
                color: Theme.muted;
                font-size: 12px;
                width: 100%;
                height: 100%;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            rt := TouchArea {
                clicked => {
                    root.restore();
                }
            }
        }

        // ---- hover action bar (bottom) ----
        HorizontalLayout {
            y: parent.height - 34px;
            height: 26px;
            width: 100%;
            alignment: center;
            spacing: 8px;
            opacity: hover.has-hover ? 1.0 : 0.0;
            animate opacity { duration: Theme.anim; }
            IconButton {
                icon: root.pause-icon;
                clicked => {
                    root.pause();
                }
            }

            IconButton {
                icon: "◉";
                primary: true;
                clicked => {
                    root.take-break();
                }
            }

            IconButton {
                icon: "⏭";
                clicked => {
                    root.skip();
                }
            }
        }

        // ---- corner resize grip (matches the Tauri drag-to-resize) ----
        resize := Rectangle {
            x: parent.width - 17px;
            y: parent.height - 17px;
            width: 14px;
            height: 14px;
            opacity: hover.has-hover ? 0.85 : 0.0;
            animate opacity { duration: Theme.anim; }
            Text {
                text: "⌟";
                color: Theme.muted;
                font-size: 14px;
                width: 100%;
                height: 100%;
                horizontal-alignment: right;
                vertical-alignment: bottom;
            }

            TouchArea {
                mouse-cursor: nwse-resize;
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                        root.start-resize();
                    }
                }
            }
        }
    }
}
